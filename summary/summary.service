[Unit]
Description=LiquidText Summary API
After=network.target

[Service]
Type=simple
User=ubuntu-test1
WorkingDirectory=/home/ubuntu-test1/summary
EnvironmentFile=/home/ubuntu-test1/summary/.env
ExecStart=/home/ubuntu-test1/summary/venv/bin/uvicorn app:app --host 0.0.0.0 --port 8010
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
